@inproceedings{Haydar2024,
 abstract = {As cities worldwide experience rapid growth, the demand for a robust infrastructure to support the evolving needs of urban residents becomes increasingly important. Managing urban water networks requires accurate and standardized data which is challenging because of the lack of interoperability and the heterogeneity of data. Our research involves leveraging the semantic web by developing an Ontology-Based Data Access system that links conceptual data models with datasets through a set of mappings.},
 author = {Haydar, Batoul and Chahinian, Nanée and Pasquier, Claude},
 booktitle = {Actes Des 10ème {{Journées Doctorales}} En {{Hydrologie Urbaine}}},
 date = {2024-10-02},
 eventtitle = {Doctoral {{Days}} in {{Urban Hydrology}} ({{JDHU}})},
 keywords = {hydroinformatics,sewer networks},
 location = {Nantes},
 title = {From {{Standards}} to an {{Ontology-Based Data Access}} System for {{Sewer Networks}}}
}

